---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
import { getGroupedPosts } from '../utils/index';

const t = useTranslations('en');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const grouped = await getGroupedPosts();
---

<Layout title={t('blog.title')} description={t('blog.description')} lang="en">
  <main>
    <h1>{t('blog.title')}</h1>
    <p>{t('blog.description')}</p>

    {grouped.map(({ category, categoryPosts }) => (
      <section>
        <h2>{category}</h2>
        <ul>
          {categoryPosts.map((post) => (
            <li>
              <a href={`${base}/${post.id.replace(/\.mdx$/, '')}/`}>
                {post.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>
</Layout>
