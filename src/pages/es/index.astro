---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';
import { getGroupedPosts } from '../../utils/index';

const t = useTranslations('es');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const grouped = await getGroupedPosts('es');
---

<Layout title={t('blog.title')} description={t('blog.description')} lang="es">
  <main>
    <h1>{t('blog.title')}</h1>
    <p>{t('blog.description')}</p>

    {grouped.map(({ category, categoryPosts }) => (
      <section>
        <h2>{category}</h2>
        <ul>
          {categoryPosts.map((post) => (
            <li>
              <a href={`${base}/es/${post.id.replace(/^es\//, '').replace(/\.mdx$/, '')}/`}>
                {post.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>
</Layout>
