---
import { getEntry, render } from 'astro:content';

interface Props {
  partial: string;
  title: string;
  lang?: 'en' | 'es';
}

const { partial, title, lang = 'en' } = Astro.props;

const collectionName = lang === 'es' ? 'partials-es' : 'partials';
const entry = await getEntry(collectionName as any, partial);

if (!entry) throw new Error(`Partial not found: ${partial} in ${collectionName}`);

const { Content } = await render(entry);
---

<details class="collapsible-partial">
  <summary>{title}</summary>
  <div class="partial-content">
    <Content />
  </div>
</details>
