---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { formatDate } from '../utils';

export interface Props {
  title: string;
  category: string;
  labUrl: string;
  date: string;
  portswiggerDescription: string;
  lang?: Lang;
}

const { title, category, labUrl, date, portswiggerDescription, lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<div>
  <h1>{title}</h1>
  <div>
    <h2>{t('post.labDescription')}</h2>
    <p>
      <strong>{category}</strong> ·
      <a href={labUrl} target="_blank" rel="noopener noreferrer">{t('post.portswiggerLab')} ↗</a>
    </p>
    <p>{portswiggerDescription}</p>
    <small>{formatDate(date, lang)}</small>
  </div>
</div>
